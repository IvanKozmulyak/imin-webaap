{
  "name": "@imin/night-kit",
  "version": "0.1.0",
  "private": true,
  "description": "IMIN nightlife design system — the className-driven primitives behind the IMIN landing + dashboard.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./src/styles.css"
  },
  "files": ["dist", "src/styles.css"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean --external react"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.0",
    "typescript": "^5.5.4"
  }
}
