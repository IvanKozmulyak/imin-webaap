// lib/db/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id                     String   @id @default(uuid())
  name                   String   @db.VarChar(255)
  description            String?  @db.VarChar(2000)
  fromDateTime           DateTime @map("from_date_time")
  toDateTime             DateTime @map("to_date_time")
  location               String   @db.VarChar(255)
  ticketUrl              String?  @map("ticket_url") @db.VarChar(500)
  imageUrl                  String?  @map("image_url") @db.VarChar(500)
  isActive                  Boolean  @default(true) @map("is_active")
  useFestivalRegistration   Boolean  @default(false) @map("use_festival_registration")
  messageLanguage           String   @default("en") @map("message_language") @db.VarChar(10) // "en" | "uk"
  createdAt              DateTime @default(now()) @map("created_at")
  // Meetup logistics coordination
  entrance               String?  @map("entrance") @db.VarChar(255) // Entrance instructions (e.g., "Main entrance, red carpet")
  emojiCode              String?  @map("emoji_code") @db.VarChar(50) // Emoji code for squad recognition (e.g., "🫐 Blue balloon")

  registrations  EventRegistration[]
  matchingGroups MatchingGroup[]
  telegramGroups TelegramGroup[]
  organizerEvents OrganizerEvent[]

  @@map("event")
}

model EventRegistration {
  id                      String   @id @default(uuid())
  eventId                  String   @map("event_id")
  name                     String   @db.VarChar(255)
  email                    String   @db.VarChar(255)
  age                      Int
  sex                      String   @db.VarChar(50)
  country                  String?  @db.VarChar(255)
  city                     String?  @db.VarChar(255)
  createdAt                DateTime @default(now()) @map("created_at")
  telegramGroupId          String?  @map("telegram_group_id")
  // Festival registration flow
  festivalJoinOption       String?  @map("festival_join_option") @db.VarChar(50) // pre_party | class_buddies | accommodation | travel
  travelMethod             String?  @map("travel_method") @db.VarChar(50)
  hasCar                   String?  @map("has_car") @db.VarChar(50)
  carSeatsAvailable        Int?     @map("car_seats_available")
  accommodationPreference  String?  @map("accommodation_preference") @db.VarChar(50)
  danceStyle               String?  @map("dance_style") @db.VarChar(50)
  danceLevel               String?  @map("dance_level") @db.VarChar(50)
  hasTicket                String?  @map("has_ticket") @db.VarChar(50)

  event                Event                       @relation(fields: [eventId], references: [id])
  languages            EventRegistrationLanguage[]
  matchingGroupMembers MatchingGroupMember[]
  telegramGroup        TelegramGroup?              @relation(fields: [telegramGroupId], references: [id])
  countdownMessages    CountdownMessage[]

  @@index([eventId])
  @@index([telegramGroupId])
  @@map("event_registration")
}

model CountdownMessage {
  id                String   @id @default(uuid())
  eventRegistrationId String @map("event_registration_id")
  messageType       String   @map("message_type") @db.VarChar(50) // "t-7" | "t-3" | "t-1"
  sentAt            DateTime @default(now()) @map("sent_at")

  eventRegistration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)

  @@unique([eventRegistrationId, messageType])
  @@index([eventRegistrationId])
  @@map("countdown_message")
}

model EventRegistrationLanguage {
  eventRegistrationId String @map("event_registration_id")
  languageCode        String @map("language_code") @db.VarChar(10)

  eventRegistration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)

  @@id([eventRegistrationId, languageCode])
  @@map("event_registration_language")
}

model Language {
  id   String @id @default(uuid())
  code String @unique @db.VarChar(10)
  name String @db.VarChar(255)

  @@index([code])
  @@map("language")
}

model MatchingGroup {
  id        String   @id @default(uuid())
  eventId   String   @map("event_id")
  createdAt DateTime @default(now()) @map("created_at")

  event     Event                   @relation(fields: [eventId], references: [id])
  languages MatchingGroupLanguage[]
  members   MatchingGroupMember[]

  @@index([eventId])
  @@map("matching_group")
}

model MatchingGroupLanguage {
  matchingGroupId String @map("matching_group_id")
  languageCode    String @map("language_code") @db.VarChar(10)

  matchingGroup MatchingGroup @relation(fields: [matchingGroupId], references: [id], onDelete: Cascade)

  @@id([matchingGroupId, languageCode])
  @@index([matchingGroupId])
  @@map("matching_group_language")
}

model MatchingGroupMember {
  matchingGroupId     String @map("matching_group_id")
  eventRegistrationId String @map("event_registration_id")

  matchingGroup     MatchingGroup     @relation(fields: [matchingGroupId], references: [id], onDelete: Cascade)
  eventRegistration EventRegistration @relation(fields: [eventRegistrationId], references: [id], onDelete: Cascade)

  @@id([matchingGroupId, eventRegistrationId])
  @@index([eventRegistrationId])
  @@map("matching_group_member")
}

model TelegramGroup {
  id             String   @id @default(uuid())
  eventId        String   @map("event_id")
  telegramChatId String?  @map("telegram_chat_id") @db.VarChar(255)
  inviteLink     String?  @map("invite_link") @db.VarChar(500)
  memberCount    Int      @default(0) @map("member_count")
  maxMembers     Int      @default(5) @map("max_members")
  isFull         Boolean  @default(false) @map("is_full")
  groupType      String?  @map("group_type") @db.VarChar(50) // pre_party | class_buddies | accommodation | travel (for festival events)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  event         Event               @relation(fields: [eventId], references: [id])
  registrations EventRegistration[]

  @@index([eventId])
  @@index([isFull])
  @@index([eventId, groupType])
  @@map("telegram_group")
}

model Organizer {
  id            String   @id @default(uuid())
  email         String   @unique @db.VarChar(255)
  name          String   @db.VarChar(255)
  organization  String   @db.VarChar(255)
  passwordHash  String   @map("password_hash") @db.VarChar(255)
  apiKey        String?  @unique @map("api_key") @db.VarChar(255)
  isActive      Boolean  @map("is_active") @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  events        OrganizerEvent[]

  @@index([email])
  @@map("organizer")
}

model OrganizerEvent {
  id              String   @id @default(uuid())
  organizerId     String   @map("organizer_id")
  eventId         String   @unique @map("event_id")
  status          String   @db.VarChar(50) @default("active") // active, paused, cancelled
  commissionRate  Float    @map("commission_rate") @default(0)
  createdAt       DateTime @default(now()) @map("created_at")
  
  organizer       Organizer @relation(fields: [organizerId], references: [id])
  event           Event     @relation(fields: [eventId], references: [id])

  @@index([organizerId])
  @@map("organizer_event")
}

model PartnerRequest {
  id              String   @id @default(uuid())
  organization    String   @db.VarChar(255)
  email           String   @db.VarChar(255)
  annualAttendees String   @map("annual_attendees") @db.VarChar(50)
  message         String?  @db.Text
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([email])
  @@index([createdAt])
  @@map("partner_request")
}

model ConversationMessage {
  id        String   @id @default(uuid())
  chatId    String   @map("chat_id") @db.VarChar(255)
  role      String   @db.VarChar(20) // 'system' | 'user' | 'assistant'
  content   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  sequence  Int      // Order of message in conversation (0 = system prompt)

  @@index([chatId, sequence])
  @@index([chatId, createdAt])
  @@map("conversation_message")
}

model Rating {
  id                     String   @id @default(uuid())
  eventId                String   @map("event_id")
  raterTelegramId        String   @map("rater_telegram_id") @db.VarChar(255)
  // Rating can be for: individual user, squad/group, or event
  targetType             String   @map("target_type") @db.VarChar(50) // 'user' | 'group' | 'event' | 'organizer'
  targetTelegramId       String?  @map("target_telegram_id") @db.VarChar(255)
  targetGroupId          String?  @map("target_group_id") @db.VarChar(255)
  // 1-5 rating score
  score                  Int      @db.SmallInt // 1-5
  // Optional review text
  review                 String?  @db.Text
  // Bad actor flag (for identifying problematic users)
  isBadActor             Boolean  @default(false) @map("is_bad_actor")
  // Categories for the rating
  category               String?  @db.VarChar(50) // 'overall' | 'friendliness' | 'reliability' | 'communication' | 'fun'
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([eventId])
  @@index([raterTelegramId])
  @@index([targetTelegramId])
  @@index([targetGroupId])
  @@index([isBadActor])
  @@unique([eventId, raterTelegramId, targetTelegramId, targetType])
  @@map("rating")
}

model BadActor {
  id                String   @id @default(uuid())
  telegramId        String   @unique @map("telegram_id") @db.VarChar(255)
  reason            String   @db.Text
  reportedByCount   Int      @default(1) @map("reported_by_count")
  firstReportedAt   DateTime @default(now()) @map("first_reported_at")
  lastReportedAt    DateTime @updatedAt @map("last_reported_at")

  @@index([telegramId])
  @@map("bad_actor")
}

// IMIN Ambassador program - for high-retention users who help with recruitment and squad creation
model Ambassador {
  id                    String   @id @default(uuid())
  telegramId            String   @unique @map("telegram_id") @db.VarChar(255)
  telegramUsername      String?  @map("telegram_username") @db.VarChar(255)
  firstName             String?  @map("first_name") @db.VarChar(255)
  // Criteria for becoming an ambassador
  eventsAttended        Int      @default(0) @map("events_attended")
  squadsCreated         Int      @default(0) @map("squads_created")
  referrals             Int      @default(0) @map("referrals")
  ratingScore           Float    @default(0) @map("rating_score") // Average rating from others
  // Status
  isActive              Boolean  @default(true) @map("is_active")
  isVerified            Boolean  @default(false) @map("is_verified") // Manually verified by admin
  // Benefits
  badge                 String?  @map("badge") @db.VarChar(50) // "gold" | "silver" | "bronze"
  commissionRate        Float    @default(0.05) @map("commission_rate") // 5% default
  // Tracking
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")
  lastActiveAt          DateTime? @map("last_active_at")

  @@index([telegramId])
  @@index([isActive])
  @@map("ambassador")
}